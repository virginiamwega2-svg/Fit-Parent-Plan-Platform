# ─── AI ──────────────────────────────────────────────────────────────
# Optional. Without this the assistant runs in mock mode (still useful
# for demos and local dev). Set on Vercel to flip to live Claude.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ─── Auth ────────────────────────────────────────────────────────────
# Used to sign session cookies. Generate with: openssl rand -base64 32
NEXT_AUTH_SECRET=

# ─── Stripe (optional, only needed for paid checkout) ────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PRICE_ID=

# ─── Email (optional) ────────────────────────────────────────────────
RESEND_API_KEY=

# ─── n8n automation (Parent Pulse weekly digest) ─────────────────────
# Optional. When unset, /api/log/session no-ops cleanly.
# Webhook URL of your n8n Webhook node (Production URL, not Test).
N8N_WEBHOOK_URL=
# Shared secret sent as `x-pulse-secret` header — n8n validates it.
# Generate with: openssl rand -base64 32
N8N_WEBHOOK_SECRET=

# ─── Site ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
