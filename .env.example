# ─── AI ──────────────────────────────────────────────────────────────
# Optional. Without this the assistant runs in mock mode (still useful
# for demos and local dev). Set on Vercel to flip to live Claude.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ─── Auth ────────────────────────────────────────────────────────────
# Used to sign session cookies. Generate with: openssl rand -base64 32
NEXT_AUTH_SECRET=

# ─── Stripe (optional, only needed for paid checkout) ────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PRICE_ID=

# ─── Email (optional) ────────────────────────────────────────────────
RESEND_API_KEY=

# ─── Site ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
