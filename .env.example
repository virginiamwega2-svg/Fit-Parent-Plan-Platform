# ─── AI ──────────────────────────────────────────────────────────────
# Optional. Without this the assistant runs in mock mode (still useful
# for demos and local dev). Set on Vercel to flip to live Claude.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ─── Auth ────────────────────────────────────────────────────────────
# Used to sign session cookies. Generate with: openssl rand -base64 32
NEXT_AUTH_SECRET=

# ─── Database ────────────────────────────────────────────────────────
# Optional. When UNSET, the app uses local SQLite (data does NOT persist on
# Vercel — fine for the demo). Set this to a Neon Postgres connection string
# to get real persistence (users, leads, saved state). Tables auto-create on
# first use — no migration step. Get one at https://neon.tech (free tier).
# Format: postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# ─── Stripe (optional, only needed for paid checkout) ────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PRICE_ID=

# ─── Email (optional) ────────────────────────────────────────────────
RESEND_API_KEY=

# ─── n8n automation (Parent Pulse weekly digest) ─────────────────────
# Optional. When unset, /api/log/session no-ops cleanly.
# Webhook URL of your n8n Webhook node (Production URL, not Test).
N8N_WEBHOOK_URL=
# Shared secret sent as `x-pulse-secret` header — n8n validates it.
# Generate with: openssl rand -base64 32
N8N_WEBHOOK_SECRET=

# ─── Site ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
